rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow write: if isAdmin() || request.auth != null;
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /terrainBoxes/{boxId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gameSystems/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /membershipAudit/{entryId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /mail/{document} {
      allow read, write: if false;  // Only Cloud Functions can write
    }
  }
}
